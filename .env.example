# ─────────────────────────────────────────────────────────────────────────────
# MINIMAX M2.7 (PRIMARY — highest priority LLM)
# ─────────────────────────────────────────────────────────────────────────────
# Get your Token Plan key from: https://platform.minimax.io/user-center/payment/token-plan
# Supr uses MiniMax M2.7 as the primary LLM when this key is present.
# API endpoint: https://api.minimax.io/v1  (OpenAI-compatible, no code changes needed)
#
# Region note: Overseas plan → api.minimax.io | China plan → api.minimaxi.com
MINIMAX_API_KEY=""

# ─────────────────────────────────────────────────────────────────────────────
# GEMINI (secondary — used if MINIMAX_API_KEY is not set)
# ─────────────────────────────────────────────────────────────────────────────

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# ─────────────────────────────────────────────────────────────────────────────
# BACKUP LLM CONFIGURATION (optional — auto-fallback if Gemini fails)
# ─────────────────────────────────────────────────────────────────────────────
# Set these to enable a second LLM provider. Supr will automatically fall
# back to this if Gemini is unavailable or returns an error.
#
# Supported backends (set BACKUP_LLM_BASE_URL accordingly):
#
#   OpenAI:        https://api.openai.com/v1          (models: gpt-4o, gpt-4o-mini)
#   Groq:          https://api.groq.com/openai/v1     (models: llama-3.3-70b-versatile, mixtral-8x7b-32768)
#   Together AI:   https://api.together.xyz/v1        (models: meta-llama/Llama-3.3-70B-Instruct-Turbo)
#   Ollama local:  http://localhost:11434/v1          (models: llama3.2, qwen2.5-coder, etc.)
#   Azure OpenAI:  https://<resource>.openai.azure.com/openai/deployments/<model>
# ─────────────────────────────────────────────────────────────────────────────

# BACKUP_LLM_API_KEY: API key for the backup provider (use "ollama" for Ollama local)
BACKUP_LLM_API_KEY=""

# BACKUP_LLM_BASE_URL: Base URL for the backup provider's OpenAI-compatible API
BACKUP_LLM_BASE_URL="https://api.openai.com/v1"

# BACKUP_LLM_MODEL: The model name to use on the backup provider
BACKUP_LLM_MODEL="gpt-4o-mini"

# BACKUP_LLM_NAME: Human-readable label shown in fallback logs (optional)
BACKUP_LLM_NAME="OpenAI"
