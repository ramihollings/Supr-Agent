# Supr environment template
# Copy to .env for local/VPS testing. Keep real secrets out of git and Docker images.
# Every variable below is read by the application; defaults in brackets are only used
# when the variable is unset.

# ─── Security & host ──────────────────────────────────────────────────────────
# Master access key for the Supr login screen. Leave blank to require first-run setup.
APP_PASSWORD=
# Long random secret used to sign session cookies. Required for production. Generate with
# `openssl rand -hex 32` or `node -e "console.log(crypto.randomBytes(32).toString('hex'))"`.
AUTH_SECRET=
# Optional legacy alias. If set, used as a fallback for AUTH_SECRET.
NEXTAUTH_SECRET=
# Public URL where Supr is served. Used in CSP and outbound links.
APP_URL=http://localhost:3001
# Bind address + port for `next start`. Matches dev defaults in package.json.
HOSTNAME=0.0.0.0
PORT=3001

# ─── Database ──────────────────────────────────────────────────────────────────
# Path to the local SQLite file. Ignored if DATABASE_URL is set.
SQLITE_DB_PATH=./supr_local.db
# Optional PostgreSQL connection. Leave blank to use SQLite.
DATABASE_URL=
PGHOST=
PGUSER=
PGPASSWORD=
PGDATABASE=
PGPORT=5432

# ─── Primary LLM providers ────────────────────────────────────────────────────
# At least one of these is required. MiniMax takes priority; Gemini is fallback.
# Get MiniMax key from: https://platform.minimax.io/user-center/payment/token-plan
MINIMAX_API_KEY=
# Get Gemini key from: https://aistudio.google.com
GEMINI_API_KEY=

# ─── Alternate providers (used by role overrides in Settings) ─────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=

# ─── Backup LLM (OpenAI-compatible) ───────────────────────────────────────────
BACKUP_LLM_API_KEY=
BACKUP_LLM_BASE_URL=https://api.openai.com/v1
BACKUP_LLM_MODEL=gpt-4o-mini
BACKUP_LLM_NAME=OpenAI

# ─── Channel integrations ─────────────────────────────────────────────────────
# Channel credentials are normally set in Settings → Integrations, but env vars
# are honored as defaults for production deployments.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
SLACK_SIGNING_SECRET=
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_TOKEN=
COMPOSIO_API_KEY=

# ─── Workspace / sandbox ──────────────────────────────────────────────────────
# Host-side workspace root (used for local Node sandbox runs).
HOST_WORKSPACE_PATH=
# Path inside the Docker container where the workspace is mounted.
CONTAINER_WORKSPACE_PATH=/app/supr_workspaces
# Path to the cloakbrowser binary, if you use the browser tool.
CLOAKBROWSER_PATH=

# ─── Runtime overrides ─────────────────────────────────────────────────────────
# Force the runtime mode. Normally set in Settings; env wins for first boot.
# Allowed: supervisor | guided | autonomous
SUPR_RUNTIME_MODE=
# Force the Docker probe result. Useful for CI where Docker isn't available.
# Set to "true" to skip probing, "false" to pretend it's missing.
SUPR_DOCKER_AVAILABLE=

# ─── Optional GCP / GCS (Cloud Run deployments) ───────────────────────────────
GCP_PROJECT_ID=
GCS_BUCKET_NAME=
