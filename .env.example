# Supr environment template
# Copy to .env for local/VPS testing. Keep real secrets out of git and Docker images.

# Required for public deployments. Use a long random value.
APP_PASSWORD=
AUTH_SECRET=

# App/network
APP_URL=http://localhost:3001
PORT=3001
HOSTNAME=0.0.0.0
SQLITE_DB_PATH=./supr_local.db

# Primary and fallback LLM providers
MINIMAX_API_KEY=
GEMINI_API_KEY=
BACKUP_LLM_API_KEY=
BACKUP_LLM_BASE_URL=https://api.openai.com/v1
BACKUP_LLM_MODEL=gpt-4o-mini
BACKUP_LLM_NAME=OpenAI

# Optional database override. Leave blank to use SQLite.
DATABASE_URL=
PGHOST=
PGUSER=
PGPASSWORD=
PGDATABASE=
PGPORT=5432

# Optional integrations
COMPOSIO_API_KEY=
GITHUB_TOKEN=
SLACK_WEBHOOK_URL=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Sandbox/runtime safety
SANDBOX_ALLOW_API_KEYS=false
HOST_WORKSPACE_PATH=
CONTAINER_WORKSPACE_PATH=/app/supr_workspaces

# Optional GCP/Kubernetes sandbox settings
GCP_PROJECT_ID=
GCS_BUCKET_NAME=
