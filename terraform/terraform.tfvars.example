project_id  = "your-gcp-project"
region      = "us-central1"
environment = "staging"
image       = "us-central1-docker.pkg.dev/your-gcp-project/supr/supr:replace-me"

# Supply sensitive variables through an approved secret workflow:
# TF_VAR_db_password, TF_VAR_app_password, TF_VAR_auth_secret,
# and optionally TF_VAR_gemini_api_key / Telegram variables.
enable_gemini   = true
enable_telegram = true
