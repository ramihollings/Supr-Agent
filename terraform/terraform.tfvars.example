project_id  = "your-gcp-project"
region      = "us-central1"
environment = "staging"
image       = "us-central1-docker.pkg.dev/your-gcp-project/supr/supr:replace-me"

# Secret values are provisioned directly in Secret Manager outside Terraform.
# Never pass credentials through TF_VAR_* or terraform.tfvars.
enable_gemini   = true
enable_telegram = true
enable_github   = true
telegram_chat_id = "replace-with-operator-chat-id"
