    "composio-core": "^0.5.39",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^16.2.6",
    "pg": "^8.11.3",
    "playwright-core": "^1.60.0",
    "postcss": "^8.5.15",
